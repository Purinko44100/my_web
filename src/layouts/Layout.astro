---
const {
	title = 'Portfolio Control Surface',
	description = 'Marathon-inspired interface for profile, work, and contact information.',
} = Astro.props;

const pathname = Astro.url.pathname;

const navItems = [
	{ href: '/', label: '首页', key: 'home' },
	{ href: '/profile', label: '个人简介', key: 'profile' },
	{ href: '/projects', label: '作品', key: 'projects' },
	{ href: '/contact', label: '联系方式', key: 'contact' },
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="shell">
			<div class="shell__blocks" aria-hidden="true">
				<span class="shell__block shell__block--1"></span>
				<span class="shell__block shell__block--2"></span>
				<span class="shell__block shell__block--3"></span>
				<span class="shell__block shell__block--4"></span>
			</div>
			<div class="shell__noise"></div>
			<div class="shell__grid"></div>
			<header class="topbar">
				<a class="brand" href="/">
					<span class="brand__eyebrow">ORBITAL DOSSIER</span>
					<span class="brand__title">WENZHUO / PORTFOLIO</span>
				</a>
				<nav class="nav" aria-label="主导航">
					{navItems.map((item) => {
						const isActive =
							item.href === '/'
								? pathname === '/'
								: pathname.startsWith(item.href);

						return (
							<a class:list={["nav__link", { 'nav__link--active': isActive }]} href={item.href}>
								<span class="nav__index">0{navItems.indexOf(item) + 1}</span>
								<span>{item.label}</span>
							</a>
						);
					})}
				</nav>
			</header>

			<main class="page-frame">
				<slot />
			</main>

			<footer class="footer">
				<p>Signal status: OPEN / Creative systems, interface direction, front-end builds.</p>
				<p>Built with Astro. Visual language references retro-futurist tactical UI, without using game assets.</p>
			</footer>
		</div>
	</body>
</html>

<style>
	:root {
		--bg: #fff6ec;
		--bg-soft: rgba(255, 248, 239, 0.88);
		--panel: rgba(255, 255, 255, 0.9);
		--panel-strong: rgba(255, 247, 240, 0.98);
		--line: rgba(255, 106, 0, 0.18);
		--line-strong: rgba(255, 106, 0, 0.64);
		--text: #23130d;
		--muted: rgba(35, 19, 13, 0.74);
		--accent: #ff5a00;
		--accent-strong: #ff7a00;
		--accent-soft: #ffd9c4;
		--accent-warm: #ff9a1f;
		--danger: #ff4036;
		--max-width: 1240px;
		--shadow: 0 24px 80px rgba(255, 106, 0, 0.14);
	}

	html {
		background:
			linear-gradient(135deg, rgba(255, 122, 0, 0.18), transparent 26%),
			radial-gradient(circle at top left, rgba(255, 133, 29, 0.26), transparent 30%),
			radial-gradient(circle at 85% 16%, rgba(255, 255, 255, 0.94), transparent 24%),
			linear-gradient(180deg, #fff7ef 0%, #fff0e1 100%);
	}

	body {
		margin: 0;
		min-height: 100vh;
		color: var(--text);
		font-family: 'IBM Plex Sans', sans-serif;
		letter-spacing: 0.01em;
	}

	a {
		color: inherit;
	}

	.shell {
		position: relative;
		min-height: 100vh;
		padding: 24px;
		box-sizing: border-box;
		overflow: hidden;
	}

	.shell__blocks {
		position: fixed;
		inset: 0;
		pointer-events: none;
	}

	.shell__block {
		position: absolute;
		display: block;
		border: 1px solid rgba(255, 106, 0, 0.16);
		box-shadow: 0 12px 40px rgba(255, 106, 0, 0.08);
	}

	.shell__block--1 {
		top: 96px;
		left: -42px;
		width: 240px;
		height: 132px;
		background: rgba(255, 106, 0, 0.92);
		transform: rotate(-8deg);
	}

	.shell__block--2 {
		top: 180px;
		right: 4%;
		width: 180px;
		height: 240px;
		background: rgba(255, 255, 255, 0.74);
		transform: rotate(11deg);
	}

	.shell__block--3 {
		bottom: 18%;
		left: 8%;
		width: 220px;
		height: 84px;
		background: rgba(255, 154, 31, 0.82);
		transform: rotate(6deg);
	}

	.shell__block--4 {
		bottom: 72px;
		right: -36px;
		width: 280px;
		height: 148px;
		background: rgba(255, 255, 255, 0.82);
		transform: rotate(-12deg);
	}

	.shell__noise,
	.shell__grid {
		position: fixed;
		inset: 0;
		pointer-events: none;
	}

	.shell__noise {
		background-image:
			radial-gradient(rgba(255, 90, 0, 0.09) 0.7px, transparent 0.7px),
			radial-gradient(rgba(35, 19, 13, 0.04) 0.7px, transparent 0.7px);
		background-position: 0 0, 12px 12px;
		background-size: 24px 24px;
		opacity: 0.12;
	}

	.shell__grid {
		background-image:
			linear-gradient(rgba(255, 106, 0, 0.08) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 106, 0, 0.08) 1px, transparent 1px);
		background-size: 72px 72px;
		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.8), transparent 92%);
	}

	.topbar,
	.page-frame,
	.footer {
		position: relative;
		z-index: 1;
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.topbar {
		display: grid;
		grid-template-columns: 1.1fr 1.4fr;
		gap: 24px;
		align-items: start;
		padding: 20px 24px;
		border: 1px solid var(--line);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 244, 233, 0.92)),
			linear-gradient(120deg, rgba(255, 106, 0, 0.08), transparent 42%);
		box-shadow: var(--shadow);
		clip-path: polygon(0 10px, 18% 0, 100% 0, 100% calc(100% - 16px), 82% 100%, 0 100%);
		backdrop-filter: blur(18px);
		transform: rotate(-0.8deg);
	}

	.brand {
		display: inline-flex;
		flex-direction: column;
		gap: 8px;
		text-decoration: none;
	}

	.brand__eyebrow,
	.brand__title,
	.nav__index,
	.footer p {
		font-family: 'IBM Plex Mono', monospace;
		text-transform: uppercase;
	}

	.brand__eyebrow {
		font-size: 0.8rem;
		color: var(--accent);
		letter-spacing: 0.28em;
	}

	.brand__title {
		font-family: 'Chakra Petch', sans-serif;
		font-size: clamp(1.5rem, 3vw, 2.5rem);
		line-height: 0.96;
		letter-spacing: 0.08em;
	}

	.nav {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 12px;
	}

	.nav__link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		padding: 14px 16px;
		text-decoration: none;
		border: 1px solid var(--line);
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 236, 223, 0.9));
		color: var(--muted);
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			background 180ms ease,
			color 180ms ease;
	}

	.nav__link:hover,
	.nav__link--active {
		transform: translate(-4px, -2px) rotate(-1deg);
		border-color: var(--line-strong);
		background: linear-gradient(90deg, rgba(255, 138, 24, 0.88), rgba(255, 255, 255, 0.98));
		color: var(--text);
	}

	.nav__link:nth-child(2n) {
		transform: translateY(12px);
	}

	.nav__link:nth-child(3n) {
		transform: translateX(8px);
	}

	.nav__index {
		font-size: 0.78rem;
		color: var(--accent);
	}

	.page-frame {
		padding: 24px 0 32px;
	}

	.footer {
		display: flex;
		justify-content: space-between;
		gap: 24px;
		padding: 0 8px 12px;
		color: var(--muted);
		transform: translateY(10px);
	}

	.footer p {
		margin: 0;
		font-size: 0.76rem;
		letter-spacing: 0.12em;
	}

	:global(.page) {
		display: grid;
		gap: 26px;
	}

	:global(.hud-panel) {
		position: relative;
		padding: 24px;
		border: 1px solid var(--line);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 245, 235, 0.95)),
			linear-gradient(135deg, rgba(255, 106, 0, 0.06), transparent 42%);
		box-shadow: var(--shadow);
		clip-path: polygon(0 14px, 10% 0, 100% 0, 100% calc(100% - 18px), 88% 100%, 0 100%);
		backdrop-filter: blur(16px);
		isolation: isolate;
	}

	:global(.hud-panel::before) {
		content: '';
		position: absolute;
		top: -14px;
		right: 24px;
		width: 108px;
		height: 44px;
		background: linear-gradient(90deg, rgba(255, 106, 0, 0.9), rgba(255, 154, 31, 0.9));
		z-index: -1;
	}

	:global(.hud-panel::after) {
		content: '';
		position: absolute;
		left: 22px;
		bottom: -14px;
		width: 132px;
		height: 20px;
		background: rgba(255, 255, 255, 0.92);
		border: 1px solid rgba(255, 106, 0, 0.18);
		z-index: -1;
	}

	:global(.eyebrow) {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		margin-bottom: 14px;
		font-family: 'IBM Plex Mono', monospace;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--accent);
	}

	:global(.eyebrow::before) {
		content: '';
		display: inline-block;
		width: 28px;
		height: 2px;
		background: var(--accent);
	}

	:global(h1),
	:global(h2),
	:global(h3) {
		margin: 0;
		font-family: 'Chakra Petch', sans-serif;
		font-weight: 600;
		letter-spacing: 0.04em;
	}

	:global(h1) {
		font-size: clamp(2.8rem, 7vw, 5.8rem);
		line-height: 0.92;
	}

	:global(h2) {
		font-size: clamp(1.5rem, 3vw, 2.2rem);
	}

	:global(p) {
		margin: 0;
		color: var(--muted);
		line-height: 1.7;
	}

	:global(.stat-grid),
	:global(.card-grid) {
		display: grid;
		gap: 16px;
	}

	:global(.stat-grid) {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	:global(.card-grid) {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	:global(.stat),
	:global(.card),
	:global(.contact-card) {
		padding: 18px;
		border: 1px solid var(--line);
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(255, 241, 228, 0.9));
		box-shadow: 0 18px 46px rgba(255, 106, 0, 0.08);
		position: relative;
		overflow: hidden;
	}

	:global(.stat::before),
	:global(.card::before),
	:global(.contact-card::before) {
		content: '';
		position: absolute;
		top: 12px;
		right: -1px;
		width: 72px;
		height: 10px;
		background: var(--accent);
		opacity: 0.88;
	}

	:global(.stat:nth-child(3n + 1)),
	:global(.card:nth-child(3n + 1)),
	:global(.contact-card:nth-child(3n + 1)) {
		transform: translate(12px, 0) rotate(-1.2deg);
	}

	:global(.stat:nth-child(3n + 2)),
	:global(.card:nth-child(3n + 2)),
	:global(.contact-card:nth-child(3n + 2)) {
		transform: translate(-6px, 18px) rotate(0.9deg);
	}

	:global(.stat:nth-child(3n)),
	:global(.card:nth-child(3n)),
	:global(.contact-card:nth-child(3n)) {
		transform: translate(16px, -10px) rotate(-0.6deg);
	}

	:global(.stat strong),
	:global(.tag),
	:global(.meta) {
		font-family: 'IBM Plex Mono', monospace;
		text-transform: uppercase;
	}

	:global(.stat strong) {
		display: block;
		margin-bottom: 10px;
		font-size: 1.8rem;
		color: var(--text);
	}

	:global(.tag-list) {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	:global(.tag) {
		padding: 7px 10px;
		border: 1px solid rgba(255, 106, 0, 0.24);
		font-size: 0.74rem;
		letter-spacing: 0.08em;
		color: var(--accent);
		background: rgba(255, 243, 232, 0.9);
	}

	:global(.button-row) {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
	}

	:global(.button) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		padding: 14px 18px;
		text-decoration: none;
		border: 1px solid var(--line-strong);
		background: linear-gradient(90deg, rgba(255, 106, 0, 0.88), rgba(255, 154, 31, 0.82));
		font-family: 'IBM Plex Mono', monospace;
		font-size: 0.82rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #fffaf5;
		transition: transform 180ms ease, background 180ms ease;
	}

	:global(.button:hover) {
		transform: translate(-4px, -2px) rotate(-1deg);
		background: linear-gradient(90deg, rgba(255, 96, 0, 0.96), rgba(255, 166, 31, 0.9));
	}

	:global(.button--secondary) {
		border-color: rgba(255, 106, 0, 0.32);
		background: linear-gradient(90deg, rgba(255, 255, 255, 0.98), rgba(255, 235, 220, 0.92));
		color: var(--accent);
	}

	:global(.button--secondary:hover) {
		background: linear-gradient(90deg, rgba(255, 255, 255, 1), rgba(255, 224, 204, 0.96));
	}

	:global(.meta) {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		color: var(--accent);
		font-size: 0.76rem;
		letter-spacing: 0.12em;
	}

	:global(.meta::before) {
		content: '';
		width: 10px;
		height: 10px;
		background: var(--accent);
		box-shadow: 0 0 16px rgba(255, 106, 0, 0.34);
	}

	@media (max-width: 900px) {
		.topbar {
			grid-template-columns: 1fr;
			transform: none;
		}

		.nav,
		:global(.card-grid),
		:global(.stat-grid) {
			grid-template-columns: 1fr;
		}

		.nav__link,
		.nav__link:nth-child(2n),
		.nav__link:nth-child(3n),
		:global(.stat:nth-child(3n + 1)),
		:global(.stat:nth-child(3n + 2)),
		:global(.stat:nth-child(3n)),
		:global(.card:nth-child(3n + 1)),
		:global(.card:nth-child(3n + 2)),
		:global(.card:nth-child(3n)),
		:global(.contact-card:nth-child(3n + 1)),
		:global(.contact-card:nth-child(3n + 2)),
		:global(.contact-card:nth-child(3n)) {
			transform: none;
		}

		.footer {
			flex-direction: column;
			transform: none;
		}
	}

	@media (max-width: 640px) {
		.shell {
			padding: 16px;
		}

		.shell__block {
			opacity: 0.4;
		}

		.topbar,
		:global(.hud-panel) {
			padding: 18px;
		}
	}
</style>
